{
  "extends": "./tsconfig.lib.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.playground.tsbuildinfo",
    "rootDir": ".",
    "types": ["vite/client"],
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "emitDeclarationOnly": false
  },
  "include": [
    "playground/**/*.ts",
    "playground/**/*.tsx",
    "playground/**/*.d.ts",
    "src/**/*.template.tsx",
    "src/vite-env.d.ts"
  ],
  "exclude": []
}
