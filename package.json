{
  "name": "@admiral-ds/admiral3-tokens",
  "version": "0.0.0",
  "description": "Themes and CSS tokens for Admiral design system 3.0",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./fonts": {
      "types": "./dist/fonts/index.d.ts",
      "import": "./dist/fonts.js"
    },
    "./styled-components": {
      "types": "./dist/styled-components.d.ts",
      "import": "./dist/styled-components.js"
    },
    "./css": "./dist/css/index.css",
    "./css/global-colors": "./dist/css/global-colors.css",
    "./css/themes": "./dist/css/themes.css",
    "./css/typography": "./dist/css/typography.css",
    "./css/theme-light": "./dist/css/theme-light.css",
    "./css/theme-dark": "./dist/css/theme-dark.css",
    "./css/theme-light-neutral": "./dist/css/theme-light-neutral.css",
    "./css/theme-dark-neutral": "./dist/css/theme-dark-neutral.css",
    "./css/radius": "./dist/css/radius.css",
    "./css/shadow": "./dist/css/shadow.css"
  },
  "keywords": [
    "AdmiralDS",
    "Admiral",
    "design-tokens",
    "css",
    "themes"
  ],
  "author": "Admiral DS team",
  "license": "See license in ./LICENSE",
  "files": [
    "dist/index.js",
    "dist/index.d.ts",
    "dist/fonts.js",
    "dist/fonts/index.d.ts",
    "dist/fonts/*.d.ts",
    "dist/styled-components.js",
    "dist/styled-components.d.ts",
    "dist/css",
    "README.md"
  ],
  "sideEffects": [
    "*.css",
    "dist/css/*.css"
  ],
  "scripts": {
    "check:fix": "npm run format && npm run lint:fix",
    "check:full": "npm run format:check && npm run lint && npm run typecheck && npm run test:run && npm run test:e2e",
    "storybook": "storybook dev -p 6006",
    "playground": "npm run build:css && vite --config vite.playground.config.ts",
    "release": "standard-version",
    "build": "vite build && npm run build:css && tsc -p tsconfig.lib.json && tsx scripts/build-dts.ts",
    "build:css": "tsx scripts/build-css.ts",
    "storybook:build": "storybook build",
    "playground:build": "vite build --config vite.playground.config.ts",
    "playground:serve": "serve -s dist-playground -l 4173",
    "pack:check": "npm pack --dry-run",
    "test:e2e": "npm run build && npm run playground:build && playwright test",
    "test:e2e-ui": "npm run build && npm run playground:build && playwright test --ui",
    "lint:fix": "eslint . --fix",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc -b tsconfig.json"
  },
  "peerDependencies": {
    "react": "^19.2.4",
    "styled-components": "^6.4.1"
  },
  "peerDependenciesMeta": {
    "styled-components": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/addon-themes": "^10.3.3",
    "@storybook/react-vite": "^10.3.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-storybook": "^10.3.3",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "prettier": "3.8.1",
    "rollup-plugin-dts": "^6.4.1",
    "serve": "^14.2.5",
    "standard-version": "^9.5.0",
    "storybook": "^10.3.3",
    "styled-components": "^6.4.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vite-plugin-svgr": "^4.5.0",
    "vitest": "^4.1.2"
  },
  "repository": "https://github.com/AdmiralDS/admiral3-tokens",
  "bugs": {
    "url": "https://github.com/AdmiralDS/admiral3-tokens/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@admiral-ds/fonts": "^2.0.0",
    "@fontsource/source-code-pro": "^5.2.7"
  }
}
